HUNTER_API_KEY=your_hunter_key
APOLLO_API_KEY=your_apollo_key
PROXY_LIST=proxy1:port,proxy2:port
REQUEST_DELAY=1.5
DB_PATH=data/yc_founders.db

# Phase 2 — YC companies API (see docs/API_RECON.md endpoint log)
YC_COMPANIES_API_URL=https://api.ycombinator.com/v0.1/companies
YC_COMPANIES_PER_PAGE=25
